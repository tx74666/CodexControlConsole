{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "codex-console-feedback",
	"main": "src/index.js",
	"compatibility_date": "2026-07-01",
	"vars": {
		"TURNSTILE_SITE_KEY": "0x4AAAAAAD5NTJoseujco8gT",
		"DEVICE_DAILY_LIMIT": "10",
		"IP_DAILY_LIMIT": "30",
		"MONTHLY_REPORT_LIMIT": "5000",
		"MONTHLY_IMAGE_BYTES_LIMIT": "1073741824",
		"ALLOW_UNVERIFIED_REPORTS": "false"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "codex-console-feedback",
			"database_id": "538c56de-340e-4dee-b688-c6d0e25c3d23"
		}
	],
	"r2_buckets": [
		{
			"binding": "IMAGES",
			"bucket_name": "codex-console-feedback-images"
		}
	]
}
